generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  extensions = [vector]
}

model Capsule {
  id              String      @id @default(uuid())
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  status          CapsuleStatus @default(PENDING)
  sourceType      SourceType
  originalContent String?       @db.Text
  
  // Stored as JSONB in Postgres
  structuredData  Json?          
  
  assets          Asset[]
  embeddings      Embedding[]
  entities        Entity[]
  
  // Privacy
  isSanitized     Boolean     @default(false)
  
  // Deduplication (Phase 2.5)
  contentHash     String?     @unique
  similarTo       String?     // Reference to similar Capsule ID
  similarityScore Float?      // 0.0 - 1.0
  
  @@index([contentHash])
}

model Asset {
  id          String   @id @default(uuid())
  capsuleId   String
  capsule     Capsule  @relation(fields: [capsuleId], references: [id])
  
  storagePath String
  mimeType    String
  size        Int
  fileName    String?
}

model Embedding {
  id          String   @id @default(uuid())
  capsuleId   String
  capsule     Capsule  @relation(fields: [capsuleId], references: [id])
  
  // Using Unsupported for pgvector until native Prisma support is full or for raw queries
  // But typically with previewFeatures we can use it more natively now, 
  // however "Unsupported" is the safest raw way if not using the very latest typed features for vector operations
  vector      Unsupported("vector(1536)") 
  
  chunkIndex  Int      @default(0)
  contentChunk String? @db.Text
}

model Entity {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  name        String
  type        String    // PERSON, ORG, LOCATION, event, etc.
  
  capsules    Capsule[] 

  @@unique([name, type])
  @@index([name])
}

enum CapsuleStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  ARCHIVED
}

enum SourceType {
  NOTE
  IMAGE
  PDF
  WEBSITE
  AUDIO
}

// Phase 2.6: Conversation History for RAG
model Conversation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  title     String?  // Auto-generated from first query
  messages  Message[]
}

model Message {
  id             String   @id @default(uuid())
  createdAt      DateTime @default(now())
  
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  
  role           String   // "user" or "assistant"
  content        String   @db.Text
  
  // For assistant messages: array of {capsuleId, title, relevance}
  sources        Json?
  
  @@index([conversationId])
}
