generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ==========================================
// 1. Capsule Layer (Event Layer)
// ==========================================
model Capsule {
  id         String  @id @default(uuid())
  rawContent String? @db.Text
  summary    String? @db.Text

  // E.g. ["NOTE", "IMAGE", "PDF", "WEBSITE", "AUDIO"]
  sourceTypes String[]

  contextScope    String?
  confidenceScore Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status      CapsuleStatus @default(PENDING)
  isSanitized Boolean       @default(false)

  // Relations
  assets           Asset[]
  capsuleEntities  CapsuleEntity[]
  capsuleRelations CapsuleRelation[]
  capsuleTags      CapsuleTag[]
  embeddings       Embedding[]
  feedback         Feedback[]
}

enum CapsuleStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  ARCHIVED
}

enum SourceType {
  NOTE
  IMAGE
  PDF
  WEBSITE
  AUDIO
}

model Asset {
  id        String  @id @default(uuid())
  capsuleId String
  capsule   Capsule @relation(fields: [capsuleId], references: [id], onDelete: Cascade)

  storagePath String
  mimeType    String
  size        Int
  fileName    String?
}

// ==========================================
// 2. Entity Layer (Stable Memory Skeleton)
// ==========================================
model Entity {
  id             String  @id @default(uuid())
  type           String // PERSON, ORG, LOCATION, EVENT, TOPIC, DOCUMENT, etc.
  canonicalName  String
  normalizedName String
  description    String? @db.Text

  firstSeenAt     DateTime @default(now())
  lastSeenAt      DateTime @default(now())
  mentionCount    Int      @default(1)
  confidenceScore Float    @default(1.0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  capsuleEntities CapsuleEntity[]
  relationsFrom   Relation[]      @relation("FromEntity")
  relationsTo     Relation[]      @relation("ToEntity")
  embeddings      Embedding[]

  @@index([normalizedName])
}

// ==========================================
// 3. Capsule_Entity (Decoupling)
// ==========================================
model CapsuleEntity {
  id        String  @id @default(uuid())
  capsuleId String
  capsule   Capsule @relation(fields: [capsuleId], references: [id], onDelete: Cascade)
  entityId  String
  entity    Entity  @relation(fields: [entityId], references: [id], onDelete: Cascade)

  role            String? // subject, object, mentioned, author
  confidenceScore Float    @default(1.0)
  createdAt       DateTime @default(now())

  @@index([capsuleId])
  @@index([entityId])
}

// ==========================================
// 4. Relation Layer (Structure)
// ==========================================
model Relation {
  id           String @id @default(uuid())
  fromEntityId String
  fromEntity   Entity @relation("FromEntity", fields: [fromEntityId], references: [id], onDelete: Cascade)
  toEntityId   String
  toEntity     Entity @relation("ToEntity", fields: [toEntityId], references: [id], onDelete: Cascade)

  relationType String // about, references, involved_in, belongs_to, etc.
  strength     Float  @default(1.0)
  createdBy    String // ai, user, system

  firstSeenAt  DateTime @default(now())
  lastSeenAt   DateTime @default(now())
  mentionCount Int      @default(1)
  createdAt    DateTime @default(now())

  capsuleRelations CapsuleRelation[]

  @@unique([fromEntityId, toEntityId, relationType])
  @@index([fromEntityId])
  @@index([toEntityId])
}

// ==========================================
// 5. Capsule_Relation (Traceability)
// ==========================================
model CapsuleRelation {
  id         String   @id @default(uuid())
  capsuleId  String
  capsule    Capsule  @relation(fields: [capsuleId], references: [id], onDelete: Cascade)
  relationId String
  relation   Relation @relation(fields: [relationId], references: [id], onDelete: Cascade)

  confidenceScore Float    @default(1.0)
  createdAt       DateTime @default(now())

  @@unique([capsuleId, relationId])
  @@index([capsuleId])
  @@index([relationId])
}

// ==========================================
// 6. Embedding Layer (Vector)
// ==========================================
model Embedding {
  id         String                      @id @default(uuid())
  objectType ObjectType // CAPSULE, ENTITY
  objectId   String
  vector     Unsupported("vector(1536)")
  modelName  String?
  createdAt  DateTime                    @default(now())

  // Optional relations to satisfy Prisma types safely
  capsuleId String?
  capsule   Capsule? @relation(fields: [capsuleId], references: [id], onDelete: Cascade)
  entityId  String?
  entity    Entity?  @relation(fields: [entityId], references: [id], onDelete: Cascade)

  // Additional fields migrated from old schema
  chunkIndex   Int     @default(0)
  contentChunk String? @db.Text

  @@index([objectId])
}

enum ObjectType {
  CAPSULE
  ENTITY
}

// ==========================================
// 7. Tag Layer (Lightweight Semantic)
// ==========================================
model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  type      String?
  createdAt DateTime @default(now())

  capsuleTags CapsuleTag[]
}

model CapsuleTag {
  id        String  @id @default(uuid())
  capsuleId String
  capsule   Capsule @relation(fields: [capsuleId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([capsuleId, tagId])
}

// ==========================================
// Phase 2.6: Conversation History for RAG
// ==========================================
model Conversation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title    String? // Auto-generated from first query
  messages Message[]
}

model Message {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role    String // "user" or "assistant"
  content String @db.Text

  // For assistant messages: array of {capsuleId, title, relevance}
  sources Json?

  @@index([conversationId])
}

// ==========================================
// Phase 2.7: Feedback System
// ==========================================
model Feedback {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  capsuleId String
  capsule   Capsule @relation(fields: [capsuleId], references: [id], onDelete: Cascade)

  type   FeedbackType
  rating Int?

  // User corrections (JSONB: { field, oldValue, newValue, reason })
  correction Json?

  flagReason String? // "incorrect", "incomplete", "irrelevant", "duplicate"
  comment    String? @db.Text

  @@index([capsuleId])
  @@index([type])
  @@index([createdAt])
}

enum FeedbackType {
  RATING
  CORRECTION
  FLAG
}

// ==========================================
// Phase 3: Spaced Repetition System
// ==========================================

model ReviewCard {
  id                String   @id @default(uuid())
  userId            String
  capsuleId         String?
  
  // Card Content
  front             String   @db.Text
  back              String   @db.Text
  cardType          CardType @default(FLASHCARD)
  
  // SM-2 Algorithm Parameters
  easinessFactor    Float    @default(2.5)
  interval          Int      @default(0)  // days
  repetitionCount   Int      @default(0)
  
  // Scheduling
  nextReviewAt      DateTime @default(now())
  lastReviewedAt    DateTime?
  status            ReviewStatus @default(NEW)
  
  // Statistics
  totalReviews      Int      @default(0)
  correctCount      Int      @default(0)
  streak            Int      @default(0)
  
  // Metadata
  tags              String[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  reviewLogs        ReviewLog[]
  sessions          ReviewSessionCard[]

  @@index([userId, nextReviewAt])
  @@index([userId, status])
  @@index([capsuleId])
}

model ReviewSession {
  id                String   @id @default(uuid())
  userId            String
  startedAt         DateTime @default(now())
  endedAt           DateTime?
  
  // Statistics
  cardsReviewed     Int      @default(0)
  correctCount      Int      @default(0)
  incorrectCount    Int      @default(0)
  averageTimePerCard Float?
  
  cards             ReviewSessionCard[]
  logs              ReviewLog[]

  @@index([userId, startedAt])
}

model ReviewSessionCard {
  id              String   @id @default(uuid())
  sessionId       String
  cardId          String
  orderIndex      Int
  
  session         ReviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  card            ReviewCard    @relation(fields: [cardId], references: [id])

  @@unique([sessionId, cardId])
  @@index([sessionId, orderIndex])
}

model ReviewLog {
  id                String   @id @default(uuid())
  userId            String
  cardId            String
  sessionId         String?
  
  // User Response
  rating            Int      // 0-5
  responseTime      Int      // seconds
  reviewedAt        DateTime @default(now())
  
  // Algorithm State (snapshot)
  previousInterval  Int
  newInterval       Int
  previousEF        Float
  newEF             Float

  card              ReviewCard    @relation(fields: [cardId], references: [id])
  session           ReviewSession? @relation(fields: [sessionId], references: [id])

  @@index([userId, reviewedAt])
  @@index([cardId, reviewedAt])
}

enum CardType {
  FLASHCARD
  QA
  FILL_BLANK
  CLOZE
}

enum ReviewStatus {
  NEW
  SCHEDULED
  LEARNING
  REVIEW
  MASTERED
  SUSPENDED
}

// ==========================================
// Phase 3: Knowledge Graph Maintenance
// ==========================================

model MaintenanceTask {
  id                String   @id @default(uuid())
  userId            String
  
  // Task Info
  taskType          MaintenanceType
  description       String   @db.Text
  status            MaintenanceStatus @default(PENDING)
  confidence        Float    // 0-1
  
  // Affected Entities/Relations
  sourceEntityId    String?
  targetEntityId    String?
  relationId        String?
  
  // Changes (JSON for flexibility)
  changes           Json?    // MaintenanceChange[]
  
  // Review
  reviewedAt        DateTime?
  reviewedBy        ReviewerType?
  reviewComment     String?
  
  // Execution
  appliedAt         DateTime?
  errorMessage      String?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId, status])
  @@index([userId, taskType])
  @@index([confidence])
}

enum MaintenanceType {
  ENTITY_MERGE
  RELATION_DISCOVERY
  TAG_OPTIMIZATION
  STALE_DETECTION
  ORPHAN_CLEANUP
}

enum MaintenanceStatus {
  PENDING
  AUTO_APPROVED
  AWAITING_USER_REVIEW
  APPROVED
  REJECTED
  APPLIED
  FAILED
  REVERTED
}

enum ReviewerType {
  USER
  SYSTEM
}

// ==========================================
// Phase 3: Insights System
// ==========================================

model Insight {
  id                String   @id @default(uuid())
  userId            String
  
  // Content
  type              InsightType
  title             String
  description       String   @db.Text
  priority          Priority
  priorityScore     Int      // 0-100
  status            InsightStatus @default(NEW)
  
  // Related Data
  relatedCapsuleIds String[]
  relatedEntityIds  String[]
  suggestedAction   String?
  extractedData     Json?    // Type-specific data (dates, etc.)
  
  // Timing
  generatedAt       DateTime @default(now())
  expiresAt         DateTime?
  actionedAt        DateTime?
  snoozedUntil      DateTime?
  
  // Feedback
  userFeedback      UserFeedback?
  
  // Deduplication
  contentHash       String   @unique
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId, status])
  @@index([userId, priority])
  @@index([userId, generatedAt])
  @@index([expiresAt])
}

enum InsightType {
  TASK_REMINDER
  KNOWLEDGE_GAP
  CONNECTION
  ACTION_SUGGESTION
  HABIT_ANALYSIS
  OPPORTUNITY
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

enum InsightStatus {
  NEW
  VIEWED
  ACTIONED
  DISMISSED
  SNOOZED
  EXPIRED
  COMPLETED
}

enum UserFeedback {
  HELPFUL
  NOT_HELPFUL
}

// ==========================================
// Phase 3: User Settings
// ==========================================

model UserSettings {
  id                String   @id @default(uuid())
  userId            String   @unique
  
  // Spaced Repetition Settings (JSON for flexibility)
  spacedRepetition  Json     // SpacedRepetitionSettings
  
  // Graph Maintenance Settings
  graphMaintenance  Json     // GraphMaintenanceSettings
  
  // Insights Settings
  insights          Json     // InsightsSettings
  
  updatedAt         DateTime @updatedAt
}
