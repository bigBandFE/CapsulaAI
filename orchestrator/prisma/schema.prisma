generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ==========================================
// 1. Capsule Layer (Event Layer)
// ==========================================
model Capsule {
  id         String  @id @default(uuid())
  rawContent String? @db.Text
  summary    String? @db.Text

  // E.g. ["NOTE", "IMAGE", "PDF", "WEBSITE", "AUDIO"]
  sourceTypes String[]

  contextScope    String?
  confidenceScore Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status      CapsuleStatus @default(PENDING)
  isSanitized Boolean       @default(false)

  // Relations
  assets           Asset[]
  capsuleEntities  CapsuleEntity[]
  capsuleRelations CapsuleRelation[]
  capsuleTags      CapsuleTag[]
  embeddings       Embedding[]
  feedback         Feedback[]
}

enum CapsuleStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  ARCHIVED
}

enum SourceType {
  NOTE
  IMAGE
  PDF
  WEBSITE
  AUDIO
}

model Asset {
  id        String  @id @default(uuid())
  capsuleId String
  capsule   Capsule @relation(fields: [capsuleId], references: [id], onDelete: Cascade)

  storagePath String
  mimeType    String
  size        Int
  fileName    String?
}

// ==========================================
// 2. Entity Layer (Stable Memory Skeleton)
// ==========================================
model Entity {
  id             String  @id @default(uuid())
  type           String // PERSON, ORG, LOCATION, EVENT, TOPIC, DOCUMENT, etc.
  canonicalName  String
  normalizedName String
  description    String? @db.Text

  firstSeenAt     DateTime @default(now())
  lastSeenAt      DateTime @default(now())
  mentionCount    Int      @default(1)
  confidenceScore Float    @default(1.0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  capsuleEntities CapsuleEntity[]
  relationsFrom   Relation[]      @relation("FromEntity")
  relationsTo     Relation[]      @relation("ToEntity")
  embeddings      Embedding[]

  @@index([normalizedName])
}

// ==========================================
// 3. Capsule_Entity (Decoupling)
// ==========================================
model CapsuleEntity {
  id        String  @id @default(uuid())
  capsuleId String
  capsule   Capsule @relation(fields: [capsuleId], references: [id], onDelete: Cascade)
  entityId  String
  entity    Entity  @relation(fields: [entityId], references: [id], onDelete: Cascade)

  role            String? // subject, object, mentioned, author
  confidenceScore Float    @default(1.0)
  createdAt       DateTime @default(now())

  @@index([capsuleId])
  @@index([entityId])
}

// ==========================================
// 4. Relation Layer (Structure)
// ==========================================
model Relation {
  id           String @id @default(uuid())
  fromEntityId String
  fromEntity   Entity @relation("FromEntity", fields: [fromEntityId], references: [id], onDelete: Cascade)
  toEntityId   String
  toEntity     Entity @relation("ToEntity", fields: [toEntityId], references: [id], onDelete: Cascade)

  relationType String // about, references, involved_in, belongs_to, etc.
  strength     Float  @default(1.0)
  createdBy    String // ai, user, system

  firstSeenAt  DateTime @default(now())
  lastSeenAt   DateTime @default(now())
  mentionCount Int      @default(1)
  createdAt    DateTime @default(now())

  capsuleRelations CapsuleRelation[]

  @@unique([fromEntityId, toEntityId, relationType])
  @@index([fromEntityId])
  @@index([toEntityId])
}

// ==========================================
// 5. Capsule_Relation (Traceability)
// ==========================================
model CapsuleRelation {
  id         String   @id @default(uuid())
  capsuleId  String
  capsule    Capsule  @relation(fields: [capsuleId], references: [id], onDelete: Cascade)
  relationId String
  relation   Relation @relation(fields: [relationId], references: [id], onDelete: Cascade)

  confidenceScore Float    @default(1.0)
  createdAt       DateTime @default(now())

  @@unique([capsuleId, relationId])
  @@index([capsuleId])
  @@index([relationId])
}

// ==========================================
// 6. Embedding Layer (Vector)
// ==========================================
model Embedding {
  id         String                      @id @default(uuid())
  objectType ObjectType // CAPSULE, ENTITY
  objectId   String
  vector     Unsupported("vector(1536)")
  modelName  String?
  createdAt  DateTime                    @default(now())

  // Optional relations to satisfy Prisma types safely
  capsuleId String?
  capsule   Capsule? @relation(fields: [capsuleId], references: [id], onDelete: Cascade)
  entityId  String?
  entity    Entity?  @relation(fields: [entityId], references: [id], onDelete: Cascade)

  // Additional fields migrated from old schema
  chunkIndex   Int     @default(0)
  contentChunk String? @db.Text

  @@index([objectId])
}

enum ObjectType {
  CAPSULE
  ENTITY
}

// ==========================================
// 7. Tag Layer (Lightweight Semantic)
// ==========================================
model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  type      String?
  createdAt DateTime @default(now())

  capsuleTags CapsuleTag[]
}

model CapsuleTag {
  id        String  @id @default(uuid())
  capsuleId String
  capsule   Capsule @relation(fields: [capsuleId], references: [id], onDelete: Cascade)
  tagId     String
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([capsuleId, tagId])
}

// ==========================================
// Phase 2.6: Conversation History for RAG
// ==========================================
model Conversation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title    String? // Auto-generated from first query
  messages Message[]
}

model Message {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role    String // "user" or "assistant"
  content String @db.Text

  // For assistant messages: array of {capsuleId, title, relevance}
  sources Json?

  @@index([conversationId])
}

// ==========================================
// Phase 2.7: Feedback System
// ==========================================
model Feedback {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  capsuleId String
  capsule   Capsule @relation(fields: [capsuleId], references: [id], onDelete: Cascade)

  type   FeedbackType
  rating Int?

  // User corrections (JSONB: { field, oldValue, newValue, reason })
  correction Json?

  flagReason String? // "incorrect", "incomplete", "irrelevant", "duplicate"
  comment    String? @db.Text

  @@index([capsuleId])
  @@index([type])
  @@index([createdAt])
}

enum FeedbackType {
  RATING
  CORRECTION
  FLAG
}
